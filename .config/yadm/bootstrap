#!/usr/bin/env bash
set -euo pipefail

export NONINTERACTIVE=1

log() {
  printf "\n==> %s\n" "$1"
}

warn() {
  printf "\n[warn] %s\n" "$1"
}

has_cmd() {
  command -v "$1" >/dev/null 2>&1
}

init_homebrew() {
  if has_cmd brew; then
    return
  fi

  log "Installing Homebrew"
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
}

init_brew_shellenv() {
  if [ -x /opt/homebrew/bin/brew ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [ -x /usr/local/bin/brew ]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi
}

install_brewfile() {
  if ! has_cmd brew; then
    warn "brew not available, skipping Brewfile"
    return
  fi

  log "Installing packages from Brewfile"
  brew bundle --file="$HOME/.Brewfile"
}

install_oh_my_zsh() {
  local omz_dir="${ZSH:-$HOME/.oh-my-zsh}"

  if [ -d "$omz_dir" ]; then
    log "Oh My Zsh already installed"
    return
  fi

  log "Installing Oh My Zsh"
  RUNZSH=no CHSH=no KEEP_ZSHRC=yes \
    sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
}

install_fonts() {
  local source_dir="$HOME/fonts"
  local font_dir

  if [[ "$(uname -s)" == "Darwin" ]]; then
    font_dir="$HOME/Library/Fonts"
  else
    font_dir="$HOME/.local/share/fonts"
  fi

  if [ ! -d "$source_dir" ]; then
    log "No ~/fonts directory found, skipping fonts"
    return
  fi

  log "Installing fonts → $font_dir"
  mkdir -p "$font_dir"

  rsync -a "$source_dir/" "$font_dir/"

  if has_cmd fc-cache; then
    log "Refreshing font cache"
    fc-cache -fv
  fi
}

post_install() {
  # fzf shell integration (idempotent)
  if has_cmd brew; then
    local brew_prefix
    brew_prefix="$(brew --prefix)"

    if [ -x "$brew_prefix/opt/fzf/install" ] && [ ! -f "$HOME/.fzf.zsh" ]; then
      log "Installing fzf shell integration"
      "$brew_prefix/opt/fzf/install" --key-bindings --completion --no-update-rc || true
    fi
  fi

  if ! has_cmd wt; then
    warn "wt not found (Warp). Install via Warp if needed."
  fi
}

main() {
  log "Starting yadm bootstrap"

  case "$(uname -s)" in
  Darwin)
    init_homebrew
    init_brew_shellenv
    install_brewfile
    ;;
  Linux)
    warn "Linux brew bundle not configured"
    ;;
  esac

  install_oh_my_zsh
  install_fonts
  post_install

  log "Bootstrap complete"

  cat <<'EOF'

Next steps:
  1. Restart your terminal
  2. Verify:
     command -v tmux mise rg fzf pnpm
  3. Run:
     yadm status

EOF
}

main "$@"
